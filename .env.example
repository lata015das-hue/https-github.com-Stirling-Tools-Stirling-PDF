# ============================================================
# ENVIRONMENT VARIABLES — COPY THIS FILE
# ============================================================
#
# For development:
#   cp .env.example .env
#   Then fill in values and start your dev server.
#
# For production:
#   cp .env.example .env.production
#   Fill in real production values. Set them as real env vars on
#   your hosting platform (Docker, systemd, Vercel, etc.)
#
# NEVER commit .env or .env.production with real values.
# This .env.example file IS committed to git as documentation.
# ============================================================

# Stirling-PDF backend URL
BACKEND_URL=http://localhost:8080

# Canonical site URL (used by sitemap, robots, canonical tags, OG, hreflang)
SITE_URL=http://localhost:3000

# Port for local dev server
PORT=3000

# Analytics (Plausible self-hosted; leave empty to disable)
ANALYTICS_ENDPOINT=
ANALYTICS_DOMAIN=

# ESP for lead-magnet-funnel (leave empty to disable)
ESP_API_KEY=
ESP_LIST_ID=

# Google Search Console export
GSC_SERVICE_ACCOUNT_KEY_PATH=
GSC_PROPERTY=

# reCAPTCHA / hCaptcha
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Signed URL secret for lead-magnet asset delivery (generate: openssl rand -hex 32)
ASSET_SIGNING_SECRET=
