# ============================================================
# ENVIRONMENT VARIABLES — COPY THIS FILE
# ============================================================
#
# For development:
#   cp .env.example .env
#   Then fill in values and start your dev server.
#
# For production:
#   cp .env.example .env.production
#   Fill in real production values. Set them as real env vars on
#   your hosting platform (Docker, systemd, Vercel, etc.)
#
# NEVER commit .env or .env.production with real values.
# This .env.example file IS committed to git as documentation.
# ============================================================

# ============================================================
# CORE — Required
# ============================================================

# Node environment: development | production
NODE_ENV=development

# API base URL (the Stirling-PDF backend)
API_BASE_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080

# JWT secret for session/token signing (generate: openssl rand -hex 32)
JWT_SECRET=

# Max file upload size in bytes (default 50MB = 52428800)
UPLOAD_LIMIT=52428800

# Canonical site URL (sitemap, robots, canonical tags, OG, hreflang)
SITE_URL=http://localhost:3000

# Port for local dev server
PORT=3000

# ============================================================
# OPTIONAL — leave empty to disable
# ============================================================

# Analytics (Plausible self-hosted)
ANALYTICS_ENDPOINT=
ANALYTICS_DOMAIN=

# ESP for lead-magnet-funnel
ESP_API_KEY=
ESP_LIST_ID=

# Google Search Console export
GSC_SERVICE_ACCOUNT_KEY_PATH=
GSC_PROPERTY=

# reCAPTCHA / hCaptcha
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Signed URL secret for lead-magnet asset delivery (generate: openssl rand -hex 32)
ASSET_SIGNING_SECRET=
